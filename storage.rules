rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Employee ID cards — authenticated users only
    match /employees/{employeeId}/{fileName} {
      allow read, write: if request.auth != null;
    }
    // Fallback — deny everything else
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
